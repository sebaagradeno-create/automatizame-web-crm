    {
      "parameters": {
        "jsCode": "const senderPsid = $('🔍 Extraer Mensaje').first().json.sender_psid;\nconst aiResponse = $input.first().json.output || $input.first().json.text || 'Disculpa, hubo un problema.';\nlet cleanResponse = aiResponse.replace(/^(assistant|aria):\\s*/gi, '').trim();\nif (cleanResponse.length > 1000) cleanResponse = cleanResponse.substring(0, 997) + '...';\nconst msgLower = ($('🔍 Extraer Mensaje').first().json.message_text || '').toLowerCase();\nlet temperature = 'frio';\nif (msgLower.includes('agendar') || msgLower.includes('reunion')) temperature = 'listo';\nelse if (msgLower.includes('precio') || msgLower.includes('presupuesto')) temperature = 'caliente';\nelse if (msgLower.includes('necesito') || msgLower.includes('ayuda')) temperature = 'tibio';\nreturn [{ json: { sender_psid: senderPsid, response_text: cleanResponse, original_message: $('🔍 Extraer Mensaje').first().json.message_text, temperature: temperature, is_hot: (temperature === 'caliente' || temperature === 'listo'), timestamp: new Date().toISOString() } }];"
      },
