    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\nlet senderPsid = '', messageText = '', messageId = '';\n\ntry {\n  const entry = body.entry?.[0] || {};\n  \n  // CASO 1: DM\n  if (entry.messaging?.[0]) {\n    const msg = entry.messaging[0];\n    if (msg.message?.is_echo || msg.delivery || msg.read) {\n      return [{ json: { skip: true, reason: 'echo' } }];\n    }\n    senderPsid = msg.sender?.id || '';\n    messageText = msg.message?.text || '';\n    messageId = msg.message?.mid || '';\n  }\n  // CASO 2: Comentario\n  else if (entry.changes?.[0]) {\n    const value = entry.changes[0].value || {};\n    senderPsid = value.from?.id || '';\n    messageText = value.text || '';\n    messageId = value.id || '';\n  }\n} catch (e) {}\n\nif (!senderPsid || !messageText) {\n  return [{ json: { skip: true, reason: 'no_valid', debug_body: body } }];\n}\n\nconst source = body.entry?.[0]?.changes?.[0] ? 'instagram_comment' : 'instagram_dm';\nreturn [{ json: { skip: false, sender_psid: senderPsid, message_text: messageText, message_id: messageId, source: source } }];\n"
      },
