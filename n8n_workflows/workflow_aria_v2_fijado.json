    {
      "parameters": {
        "httpMethod": "POST",
        "path": "instagram-dm-webhook-v2",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "ig-wh-post",
      "name": "📥 Instagram Webhook",
      "position": [
        -704,
        400
      ],
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "webhookId": "ig-webhook-v2"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\nlet senderPsid = '';\nlet messageText = '';\nlet messageId = '';\nlet timestamp = Date.now().toString();\ntry {\n  const entry = body.entry?.[0];\n  if (entry?.messaging?.[0]) {\n    const msg = entry.messaging[0];\n    if (msg.message?.is_echo || msg.delivery || msg.read) {\n      return [{ json: { skip: true, reason: 'echo_or_system' } }];\n    }\n    senderPsid = msg.sender?.id || '';\n    messageText = msg.message?.text || '';\n    messageId = msg.message?.mid || '';\n    timestamp = msg.timestamp || timestamp;\n  }\n  if (!messageText && entry?.changes?.[0]) {\n    const change = entry.changes[0];\n    const value = change.value || {};\n    senderPsid = value.from?.id || value.sender?.id || '';\n    messageText = value.message?.text || value.text || '';\n    messageId = value.message?.mid || value.id || '';\n    timestamp = value.timestamp || timestamp;\n  }\n} catch (e) {\n  senderPsid = body.sender_id || body.from || '';\n  messageText = body.message || body.text || '';\n}\nif (!senderPsid || !messageText) {\n  return [{ json: { skip: true, reason: 'no_valid_message' } }];\n}\nreturn [{ json: { skip: false, sender_psid: senderPsid, message_text: messageText, message_id: messageId, timestamp: timestamp, source: 'instagram_dm' } }];"
      },
      "id": "ig-extract",
      "name": "🔍 Extraer Mensaje",
      "position": [
        -400,
        400
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
