        "query": "INSERT INTO ig_leads (instagram_psid, last_message, ai_response, temperature, source, created_at, updated_at)\nVALUES (\n  '{{ $json.sender_psid }}',\n  '{{ $json.original_message }}',\n  '{{ $json.response_text }}',\n  '{{ $json.temperature }}',\n  'instagram_dm', NOW(), NOW()\n)\nON CONFLICT (instagram_psid)\nDO UPDATE SET\n  last_message = EXCLUDED.last_message,\n  ai_response = EXCLUDED.ai_response,\n  temperature = EXCLUDED.temperature,\n  conversation_count = ig_leads.conversation_count + 1,\n  updated_at = NOW();",
