    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nreturn [{\n  json: {\n    ...item,\n    caption_final: $node[\"AI Agent\"].json.output.split('[CAPTION]')[1].split('[IMAGE_PROMPT]')[0].trim()\n  }\n}];"
      },
      "name": "Limpiar Caption",
      "type": "n8n-nodes-base.code",
      "position": [
        1080,
        300
      ]
