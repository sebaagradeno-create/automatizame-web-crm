{
  "name": "🎬 IA Viral Generator - Automatízame PRO (v5 INTERACTIVO)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
