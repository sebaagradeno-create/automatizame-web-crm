          "id": "GjNcpfBPkLl05TYn",
          "name": "Google Gemini(PaLM) Api account 6"
        }
      },
      "id": "node-gemini-001"
    },
    {
      "parameters": {
        "name": "={{ $now.format('yyyy-MM-dd_HH-mm') }}.png",
        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "value": "1KMCXu1SjTL0d17o6U6Rydikn3YkQWlrS",
          "mode": "list"
        }
      },
      "name": "Upload Drive",
      "type": "n8n-nodes-base.googleDrive",
