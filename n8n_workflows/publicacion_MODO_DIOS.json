      "type": "n8n-nodes-cloudinary.cloudinary",
      "typeVersion": 1,
      "position": [
        1080,
        300
      ],
      "credentials": {
        "cloudinaryApi": {
          "id": "2O1MemHlGqL0VBIA",
          "name": "Cloudinary account"
        }
      },
      "id": "node-cloudinary-001"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nlet caption = \"\";\ntry {\n  caption = $node[\"AI Agent\"].json.output.split('[CAPTION]')[1].split('[IMAGE_PROMPT]')[0].trim();\n} catch(e) {\n  caption = \"Innovando el futuro en automatizameuy.com 🦾✨\";\n}\nreturn [{\n  json: {\n    ...item,\n    caption_final: caption\n  }\n}];"
      },
      "name": "Build State",
      "type": "n8n-nodes-base.code",
      "position": [
        1300,
        300
      ],
      "id": "node-code-001"
    },
    {
      "parameters": {
        "operation": "sendPhoto",
        "chatId": "1301491979",
        "photo": "={{ $json.secure_url }}",
        "caption": "=🤖 POST GUARDADO EN DRIVE.\n\nSE PUBLICARÁ EN 5 MINUTOS ⏳\n\n📝 TEXTO:\n{{ $json.caption_final }}\n\n(Toca un botón para cambiar) 👇",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "inline_keyboard": [
            [
              {
                "text": "🔄 Mala Foto",
                "url": "={{ $execution.resumeUrl }}?action=photo"
              },
              {
                "text": "📝 Mal Texto",
                "url": "={{ $execution.resumeUrl }}?action=text"
              }
            ],
            [
              {
                "text": "✅ Publicar YA",
                "url": "={{ $execution.resumeUrl }}?action=si"
              },
              {
                "text": "❌ Cancelar",
