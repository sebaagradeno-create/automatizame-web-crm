      "credentials": {
        "telegramApi": {
          "id": "EMkuSuIvQQU1R3I0",
          "name": "asistente"
        }
      }
    },
    {
      "parameters": {
        "resume": "webhook",
        "limitWaitTime": 5,
        "unit": "minutes"
      },
      "id": "node-wait-v2",
      "name": "Espera 5 Min",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        1740,
        300
