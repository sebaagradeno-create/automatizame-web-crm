        "driveId": {
          "__rl": true,
          "mode": "list",
          "value": "My Drive"
        },
        "folderId": {
          "__rl": true,
          "value": "1KMCXu1SjTL0d17o6U6Rydikn3YkQWlrS",
          "mode": "list"
        },
        "options": {}
      },
      "id": "9f8fa414-0c01-4d4f-bff8-0948995eb7a2",
      "name": "Upload Drive",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        860,
        300
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "kAWoxsZ2lzLkD2It",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "operation": "uploadFile",
        "additionalFieldsFile": {}
      },
      "id": "344bdb46-53c4-45f1-8ce6-66662e2b01dc",
      "name": "Upload Cloudinary",
      "type": "n8n-nodes-cloudinary.cloudinary",
      "typeVersion": 1,
      "position": [
        1080,
        300
      ],
      "credentials": {
        "cloudinaryApi": {
          "id": "2O1MemHlGqL0VBIA",
          "name": "Cloudinary account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nreturn [{ json: { ...item, caption_final: $node[\"AI Agent\"].json.output.split('[CAPTION]')[1].split('[IMAGE_PROMPT]')[0].trim() } }];"
      },
      "id": "node-code-v2",
      "name": "Build State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ]
    },
    {
      "parameters": {
        "operation": "sendPhoto",
        "chatId": "1301491979",
        "photo": "={{ $json.secure_url }}",
        "caption": "=🤖 POST LISTO.\n\n📝 TEXTO:\n{{ $json.caption_final }}\n\nTienes 5 min para cancelar.",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "inline_keyboard": [
            [
              {
                "text": "❌ Cancelar",
                "url": "={{ $execution.resumeUrl }}?action=no"
              }
            ]
          ]
        }
      },
      "id": "node-telegram-v2",
      "name": "Aviso Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
